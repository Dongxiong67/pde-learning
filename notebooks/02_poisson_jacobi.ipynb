   "source": [
    "## 8. SOR 松弛因子 $\\omega$ 的影响\n",
    "\n",
    "测试不同 $\\omega$ 下 SOR 的收敛步数，验证理论最佳 $\\omega^* = \\frac{2}{1 + \\sin(\\pi h)}$。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "N_test = 41\n",
    "h_test = 1.0 / (N_test - 1)\n",
    "omega_opt = 2.0 / (1.0 + np.sin(np.pi * h_test))\n",
    "\n",
    "omegas = np.linspace(1.0, 2.0, 21)\n",
    "iterations = []\n",
    "\n",
    "x = np.linspace(0, 1, N_test)\n",
    "y = np.linspace(0, 1, N_test)\n",
    "X, Y = np.meshgrid(x, y, indexing='ij')\n",
    "f = 2 * np.pi**2 * np.sin(np.pi * X) * np.sin(np.pi * Y)\n",
    "b_test = h_test**2 * f\n",
    "\n",
    "for omega in omegas:\n",
    "    _, errs = sor_solver(b_test, N_test, omega=omega, max_iter=5000, tol=1e-8)\n",
    "    iterations.append(len(errs))\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(omegas, iterations, 'bo-', linewidth=2, markersize=6)\n",
    "plt.axvline(x=omega_opt, color='r', linestyle='--', linewidth=2, label=f'理论最佳 $\\\\omega^* = {omega_opt:.4f}$')\n",
    "plt.xlabel('松弛因子 $\\\\omega$')\n",
    "plt.ylabel('收敛步数')\n",
    "plt.title(f'SOR 松弛因子对收敛速度的影响（N={N_test}）')\n",
    "plt.legend()\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()\n",
    "\n",
    "min_iter = min(iterations)\n",
    "min_omega = omegas[iterations.index(min_iter)]\n",
    "print(f'理论最佳 ω = {omega_opt:.4f}')\n",
    "print(f'实测最佳 ω = {min_omega:.4f}（{min_iter} 步）')"
