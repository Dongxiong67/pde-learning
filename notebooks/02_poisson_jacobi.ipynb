    "plt.show()\n",
    "\n",
    "print(f'\\n收敛步数对比：')\n",
    "print(f'  Jacobi       : {len(err_jacobi):>6d} 步')\n",
    "print(f'  Gauss-Seidel : {len(err_gs):>6d} 步  (约为 Jacobi 的一半)')\n",
    "print(f'  SOR          : {len(err_sor):>6d} 步  (显著加速)')"
   ]
  },
