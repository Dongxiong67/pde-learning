    "ax1.plot_surface(X, Y, f, cmap='viridis')\n",
    "ax1.set_title('源项 $f(x,y)$')\n",
    "ax1.set_xlabel('x'); ax1.set_ylabel('y')\n",
    "\n",
    "ax2 = fig.add_subplot(132, projection='3d')\n",
    "ax2.plot_surface(X, Y, u_exact, cmap='plasma')\n",
    "ax2.set_title('解析解 $u(x,y)$')\n",
    "ax2.set_xlabel('x'); ax2.set_ylabel('y')\n",
    "\n",
    "ax3 = fig.add_subplot(133)\n",
    "cs = ax3.contourf(X, Y, u_exact, 20, cmap='plasma')\n",
    "plt.colorbar(cs, ax=ax3)\n",
    "ax3.set_title('解析解等高线')\n",
    "ax3.set_xlabel('x'); ax3.set_ylabel('y')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Jacobi 迭代\n",
    "\n",
    "**特点**：所有节点同时更新，使用上一步的值。\n",
    "\n",
    "**适用场景**：天然并行，但收敛慢。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def jacobi_solver(b, N, max_iter=5000, tol=1e-8):\n",
    "    \"\"\"Jacobi 迭代求解二维 Poisson 方程。\"\"\"\n",
    "    u = np.zeros((N, N))  # 初始猜测（边界已为 0，符合 Dirichlet 条件）\n",
    "    errors = []\n",
    "    \n",
    "    for k in range(max_iter):\n",
    "        u_new = u.copy()\n",
    "        # 更新内部节点\n",
    "        u_new[1:-1, 1:-1] = 0.25 * (\n",
    "            u[2:, 1:-1] + u[:-2, 1:-1] +\n",
    "            u[1:-1, 2:] + u[1:-1, :-2] +\n",
    "            b[1:-1, 1:-1]\n",
    "        )\n",
    "        \n",
    "        # 收敛判断（用无穷范数）\n",
    "        diff = np.max(np.abs(u_new - u))\n",
    "        errors.append(diff)\n",
    "        \n",
    "        u = u_new\n",
    "        if diff < tol:\n",
    "            print(f'Jacobi 收敛于第 {k+1} 步，残差 = {diff:.2e}')\n",
    "            return u, errors\n",
    "    \n",
    "    print(f'Jacobi 未收敛，最大残差 = {errors[-1]:.2e}')\n",
    "    return u, errors\n",
    "\n",
    "u_jacobi, err_jacobi = jacobi_solver(b, N, max_iter=10000, tol=1e-8)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Gauss-Seidel 迭代\n",
    "\n",
    "**特点**：使用最新值，串行更新，收敛比 Jacobi 快约一倍。\n",
    "\n",
    "**注意**：为了向量化，这里用"红黑排序"（red-black ordering）实现 Gauss-Seidel。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def gauss_seidel_solver(b, N, max_iter=5000, tol=1e-8):\n",
    "    \"\"\"Gauss-Seidel 迭代（红黑排序）求解二维 Poisson 方程。\"\"\"    \n",
    "    u = np.zeros((N, N))\n",
    "    errors = []\n",
    "    \n",
    "    for k in range(max_iter):\n",
    "        u_old = u.copy()\n",
    "        \n",
    "        # 红点更新：i+j 为偶数\n",
    "        # 用切片访问红点 (stride=2)\n",
    "        u[1:-1:2, 1:-1:2] = 0.25 * (\n",
    "            u[2::2, 1:-1:2] + u[:-2:2, 1:-1:2] +\n",
    "            u[1:-1:2, 2::2] + u[1:-1:2, :-2:2] +\n",
    "            b[1:-1:2, 1:-1:2]\n",
    "        )\n",
    "        u[2:-1:2, 2:-1:2] = 0.25 * (\n",
    "            u[3::2, 2:-1:2] + u[1:-2:2, 2:-1:2] +\n",
    "            u[2:-1:2, 3::2] + u[2:-1:2, 1:-2:2] +\n",
    "            b[2:-1:2, 2:-1:2]\n",
    "        )\n",
    "        \n",
    "        # 黑点更新：i+j 为奇数\n",
    "        u[2:-1:2, 1:-1:2] = 0.25 * (\n",
    "            u[3::2, 1:-1:2] + u[1:-2:2, 1:-1:2] +\n",
    "            u[2:-1:2, 2::2] + u[2:-1:2, :-2:2] +\n",
    "            b[2:-1:2, 1:-1:2]\n",
    "        )\n",
    "        u[1:-1:2, 2:-1:2] = 0.25 * (\n",
    "            u[2::2, 2:-1:2] + u[:-2:2, 2:-1:2] +\n",
    "            u[1:-1:2, 3::2] + u[1:-1:2, 1:-2:2] +\n",
    "            b[1:-1:2, 2:-1:2]\n",
    "        )\n",
    "        \n",
    "        diff = np.max(np.abs(u - u_old))\n",
    "        errors.append(diff)\n",
    "        \n",
    "        if diff < tol:\n",
    "            print(f'Gauss-Seidel 收敛于第 {k+1} 步，残差 = {diff:.2e}')\n",
    "            return u, errors\n",
    "    \n",
    "    print(f'Gauss-Seidel 未收敛，最大残差 = {errors[-1]:.2e}')\n",
    "    return u, errors\n",
    "\n",
    "u_gs, err_gs = gauss_seidel_solver(b, N, max_iter=10000, tol=1e-8)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. SOR（逐次超松弛）\n",
    "\n",
    "**特点**：在 Gauss-Seidel 基础上加速，最佳松弛因子 $\\omega^* = \\frac{2}{1 + \\sin(\\pi h)}$。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def sor_solver(b, N, omega=None, max_iter=5000, tol=1e-8):\n",
    "    \"\"\"SOR 迭代求解二维 Poisson 方程。\"\"\"\n",
    "    if omega is None:\n",
    "        h = 1.0 / (N - 1)\n",
    "        omega = 2.0 / (1.0 + np.sin(np.pi * h))  # 最佳松弛因子\n",
    "    \n",
    "    u = np.zeros((N, N))\n",
    "    errors = []\n",
    "    \n",
    "    for k in range(max_iter):\n",
    "        u_old = u.copy()\n",
    "        \n",
    "        # 红黑排序 SOR\n",
    "        # 红点\n",
    "        u[1:-1:2, 1:-1:2] = (1 - omega) * u[1:-1:2, 1:-1:2] + omega * 0.25 * (\n",
    "            u[2::2, 1:-1:2] + u[:-2:2, 1:-1:2] +\n",
    "            u[1:-1:2, 2::2] + u[1:-1:2, :-2:2] +\n",
    "            b[1:-1:2, 1:-1:2]\n",
    "        )\n",
    "        u[2:-1:2, 2:-1:2] = (1 - omega) * u[2:-1:2, 2:-1:2] + omega * 0.25 * (\n",
    "            u[3::2, 2:-1:2] + u[1:-2:2, 2:-1:2] +\n",
    "            u[2:-1:2, 3::2] + u[2:-1:2, 1:-2:2] +\n",
    "            b[2:-1:2, 2:-1:2]\n",
    "        )\n",
    "        \n",
    "        # 黑点\n",
    "        u[2:-1:2, 1:-1:2] = (1 - omega) * u[2:-1:2, 1:-1:2] + omega * 0.25 * (\n",
    "            u[3::2, 1:-1:2] + u[1:-2:2, 1:-1:2] +\n",
    "            u[2:-1:2, 2::2] + u[2:-1:2, :-2:2] +\n",
    "            b[2:-1:2, 1:-1:2]\n",
    "        )\n",
    "        u[1:-1:2, 2:-1:2] = (1 - omega) * u[1:-1:2, 2:-1:2] + omega * 0.25 * (\n",
    "            u[2::2, 2:-1:2] + u[:-2:2, 2:-1:2] +\n",
    "            u[1:-1:2, 3::2] + u[1:-1:2, 1:-2:2] +\n",
    "            b[1:-1:2, 2:-1:2]\n",
    "        )\n",
    "        \n",
    "        diff = np.max(np.abs(u - u_old))\n",
    "        errors.append(diff)\n",
    "        \n",
    "        if diff < tol:\n",
    "            print(f'SOR (ω={omega:.4f}) 收敛于第 {k+1} 步，残差 = {diff:.2e}')\n",
    "            return u, errors\n",
    "    \n",
    "    print(f'SOR 未收敛，最大残差 = {errors[-1]:.2e}')\n",
    "    return u, errors\n",
    "\n",
    "u_sor, err_sor = sor_solver(b, N, max_iter=10000, tol=1e-8)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 收敛速度对比"
